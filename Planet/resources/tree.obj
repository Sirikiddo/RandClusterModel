# Modular Tree - Trunk and Foliage as separate objects
# Ствол и крона как отдельные объекты в одном файле

# ========== TRUNK OBJECT ==========
o trunk

# Trunk vertices (ствол)
v -0.06 0.0 -0.06    # 1
v  0.06 0.0 -0.06    # 2  
v  0.06 0.0  0.06    # 3
v -0.06 0.0  0.06    # 4
v -0.04 1.0 -0.04    # 5
v  0.04 1.0 -0.04    # 6
v  0.04 1.0  0.04    # 7
v -0.04 1.0  0.04    # 8

# Trunk faces
f 1 2 6
f 1 6 5
f 2 3 7
f 2 7 6
f 3 4 8
f 3 8 7
f 4 1 5
f 4 5 8
f 5 6 7
f 5 7 8

# ========== FOLIAGE OBJECT ==========
o foliage

# Foliage vertices (крона)
v -0.8 0.8 -0.8      # 9
v  0.8 0.8 -0.8      # 10
v  0.8 0.8  0.8      # 11
v -0.8 0.8  0.8      # 12
v -1.0 1.3 -1.0      # 13
v  1.0 1.3 -1.0      # 14
v  1.0 1.3  1.0      # 15
v -1.0 1.3  1.0      # 16
v -0.7 1.8 -0.7      # 17
v  0.7 1.8 -0.7      # 18
v  0.7 1.8  0.7      # 19
v -0.7 1.8  0.7      # 20
v  0.0 2.2  0.0      # 21

# Foliage faces - нижняя часть
f 9 10 14
f 9 14 13
f 10 11 15
f 10 15 14
f 11 12 16
f 11 16 15
f 12 9 13
f 12 13 16

# Средняя часть
f 13 14 18
f 13 18 17
f 14 15 19
f 14 19 18
f 15 16 20
f 15 20 19
f 16 13 17
f 16 17 20

# Верхняя часть
f 17 18 21
f 18 19 21
f 19 20 21
f 20 17 21

# Горизонтальные грани
f 9 10 11
f 9 11 12
f 13 14 15
f 13 15 16
f 17 18 19
f 17 19 20