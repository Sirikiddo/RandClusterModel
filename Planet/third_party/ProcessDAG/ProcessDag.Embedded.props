<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProcessDagIncludeLogging Condition="'$(ProcessDagIncludeLogging)'==''">0</ProcessDagIncludeLogging>
    <ProcessDagIncludeFileSchema Condition="'$(ProcessDagIncludeFileSchema)'==''">0</ProcessDagIncludeFileSchema>
    <ProcessDagIncludeScenario Condition="'$(ProcessDagIncludeScenario)'==''">0</ProcessDagIncludeScenario>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>$(MSBuildThisFileDirectory)include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <EnableModules>true</EnableModules>
      <BuildStlModules>true</BuildStlModules>
      <ScanSourceForModuleDependencies>true</ScanSourceForModuleDependencies>
      <TranslateIncludes>false</TranslateIncludes>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="$(MSBuildThisFileDirectory)proc\Proc.ixx" />
    <ClCompile Include="$(MSBuildThisFileDirectory)proc\Proc.Core.ixx" />
    <ClCompile Include="$(MSBuildThisFileDirectory)proc\Proc.Schema.ixx" />
    <ClCompile Include="$(MSBuildThisFileDirectory)core\DataSpecV2.cpp" />
    <ClCompile Include="$(MSBuildThisFileDirectory)core\NodeFactory.cpp" />
    <ClCompile Include="$(MSBuildThisFileDirectory)DAG\Commit.cpp" />
    <ClCompile Include="$(MSBuildThisFileDirectory)DAG\DagEngine.cpp" />
  </ItemGroup>

  <ItemGroup Condition="'$(ProcessDagIncludeLogging)'=='1'">
    <ClCompile Include="$(MSBuildThisFileDirectory)proc\Proc.Logging.ixx" />
    <ClCompile Include="$(MSBuildThisFileDirectory)boundary\Logger.cpp" />
  </ItemGroup>

  <ItemGroup Condition="'$(ProcessDagIncludeFileSchema)'=='1'">
    <ClCompile Include="$(MSBuildThisFileDirectory)proc\Proc.FileSchema.ixx" />
  </ItemGroup>

  <ItemGroup Condition="'$(ProcessDagIncludeScenario)'=='1'">
    <ClCompile Include="$(MSBuildThisFileDirectory)proc\Proc.Scenario.ixx" />
    <ClCompile Include="$(MSBuildThisFileDirectory)boundary\ScenarioReader.cpp" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="$(MSBuildThisFileDirectory)include\proc\ProcessDag.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)include\proc\Schema.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)include\proc\Logging.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)include\proc\FileSchema.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)include\proc\ScenarioReader.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)core\BuiltinRegistries.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)core\GraphSchema.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)core\GraphSchemaCompile.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)core\NodeFactory.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)core\SpecBinding.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\Commit.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\CoreV2.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\DagEngine.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\DagEngine.inl" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\DagStorage.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\Executor.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\LayeredState.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\MemoryPolicy.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\Planner.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\PortStates.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\ProcTypes.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\RuntimeOperationRegistry.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\StateTypes.h" />
    <ClInclude Include="$(MSBuildThisFileDirectory)DAG\StoreTypes.h" />
  </ItemGroup>
</Project>
